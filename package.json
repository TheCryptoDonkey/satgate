    "@thecryptodonkey/toll-booth": "^2.0.0",
    "402-announce": "^1.1.2",
    "hono": "^4.0.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "402-mcp": "file:../402-mcp",
    "bolt11": "^1.4.1",
