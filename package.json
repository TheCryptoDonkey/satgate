{
  "name": "token-toll",
  "version": "0.1.0",
  "description": "Lightning-paid AI inference - monetise any OpenAI-compatible endpoint in 30 seconds",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "token-toll": "./dist/bin/token-toll.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "@noble/curves": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@thecryptodonkey/toll-booth": "^1.1.2",
    "hono": "^4.0.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "keywords": [
    "lightning",
    "l402",
    "ai",
    "inference",
    "llm",
    "bitcoin",
    "payments"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheCryptoDonkey/token-toll"
